APP_NAME="Heliora Backend"
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

ENABLE_MEMORY_SERVICE=true
MEMORY_GRAPH_RETRIEVAL_P1=true

SECURITY_POLICY_MODE=strict
LOCAL_MAX_PRIVILEGE_ACK=false
LOCAL_MAX_PRIVILEGE_LOOPBACK_ONLY=true
IDEMPOTENCY_TTL_SECONDS=86400
CHAT_MAX_CONTENT_CHARS=4000
MEMORY_MAX_QUERY_CHARS=512
TASK_QUEUE_BACKEND=memory
TASK_RETRY_MAX_ATTEMPTS=2
TASK_RETRY_BASE_DELAY_SECONDS=1.0
TASK_RETRY_MAX_DELAY_SECONDS=30.0
TASK_RETRY_BACKOFF_FACTOR=2.0
TASK_QUEUE_FAIL_OPEN=true
TASK_PERSISTENCE_BACKEND=sqlite
TASK_REGISTRY_PERSISTENCE_ENABLED=true
TASK_REGISTRY_SQLITE_PATH=.data/task_registry.db
TASK_REGISTRY_POSTGRES_DSN=
TASK_QUEUE_SLA_P0_MS=3000
TASK_QUEUE_SLA_P1_MS=3000
TASK_QUEUE_SLA_P2_MS=15000
TASK_QUEUE_SLA_P3_MS=300000
TASK_QUEUE_SLA_MEMORY_MS=5000
TASK_EVENTS_PERSISTENCE_ENABLED=true
TASK_EVENTS_SQLITE_PATH=.data/task_events.db
TASK_EVENTS_POSTGRES_DSN=
TASK_WORKER_API_BASE_URL=http://127.0.0.1:8000
TASK_WORKER_QUEUE=
TASK_WORKER_IDLE_SECONDS=1.0
TASK_WORKER_BUSY_SECONDS=0.1
TASK_WORKER_ERROR_BACKOFF_SECONDS=2.0
TASK_WORKER_TRACE_PREFIX=trc_worker
TASK_WORKER_LOG_LEVEL=INFO
START_TASK_WORKER_WITH_API=true
STOP_TASK_WORKER_WITH_API=true

# Infra connection settings (dev defaults)
DATABASE_URL=postgresql://heliora:heliora_pg_pass@127.0.0.1:5432/heliora
POSTGRES_DB=heliora
POSTGRES_USER=heliora
POSTGRES_PASSWORD=heliora_pg_pass

REDIS_URL=redis://127.0.0.1:6379/0

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=heliora_neo4j_pass
NEO4J_AUTH=neo4j/heliora_neo4j_pass

RABBITMQ_URL=amqp://heliora:heliora_rmq_pass@127.0.0.1:5672/
RABBITMQ_DEFAULT_USER=heliora
RABBITMQ_DEFAULT_PASS=heliora_rmq_pass

MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ROOT_USER=heliora
MINIO_ROOT_PASSWORD=heliora_minio_pass
